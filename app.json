{
  "expo": {
    "name": "Pulse",
    "slug": "pulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pulse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FAF5EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mantaray.pulse"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF5EB"
      },
      "package": "com.mantaray.pulse"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2D5F3F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
